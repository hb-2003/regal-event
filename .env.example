# Required: long random string. Generate with `openssl rand -base64 48`
JWT_SECRET=

# Initial admin credentials (only used when seeding the DB for the first time)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# SMTP for transactional email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Regal Event London <noreply@regalevent.co.uk>"
ADMIN_EMAIL=admin@regalevent.co.uk

# Public site URL (used in email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
